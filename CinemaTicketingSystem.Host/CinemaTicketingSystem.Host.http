@HostAddress = http://localhost:5094

###
POST {{HostAddress}}/api/v1/cinema-management/movies
Accept: application/json
Content-Type: application/json
{
  "title": "Inception 4",
  "originalTitle": "Inception",
  "description": "A mind-bending thriller that delves into the world of dreams.",
  "EarliestShowingDate": "2026-07-16T00:00:00Z",
  "duration": "02:30:00",
  "posterImageUrl":"http://wwww.abc.com",
  "supportedTechnology":1
}

###
POST {{HostAddress}}/api/v1/cinema-management/cinemas
Accept: application/json
Content-Type: application/json
{
  "name": "Galaxy Cinema Mall",
  "address": {
    "country": "Turkey",
    "city": "Istanbul",
    "district": "Beyoğlu",
    "street": "İstiklal Caddesi No: 123",
    "postalCode": "34430",
    "description": "Located in the heart of Beyoğlu, next to Galatasaray High School"
  }
}

